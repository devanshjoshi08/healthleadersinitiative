# Sanity. Fill these in after creating a free project (see SANITY_SETUP.md).
# Copy this file to .env.local for local development.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# On-site editor (/edit)
SITE_EDIT_PASSWORD=
# Sanity token with write access, so the editor can save. Create it in
# sanity.io/manage -> API -> Tokens (Editor permission).
SANITY_API_WRITE_TOKEN=
